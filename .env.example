# =========================================
# Application
# =========================================
NODE_ENV=development
PORT=3000
PUBLIC_APP_URL=http://localhost:3000

# =========================================
# Database
# =========================================
DB_CONNECTION_STRING=

# =========================================
# JWT
# =========================================
JWT_SECRET=
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRES_IN=7d

# =========================================
# Google OAuth
# =========================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# =========================================
# Meta Graph (Instagram)
# =========================================
META_GRAPH_API_VERSION=v25.0
META_SYSTEM_IG_USER_ID=
META_SYSTEM_ACCESS_TOKEN=

# =========================================
# AI providers (keys)
# =========================================
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_API_KEY=
STABILITY_API_KEY=
FAL_API_KEY=
REPLICATE_API_TOKEN=
IMAGE_GENERATOR=openai

# =========================================
# S3 / Storage
# =========================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
S3_BUCKET=

# =========================================
# Mail (abstraction)
# =========================================
MAIL_PROVIDER=console
MAIL_FROM="InstaVibe <no-reply@instavibe.app>"
EMAIL_VERIFICATION_CODE_TTL_MIN=30
PASSWORD_RESET_CODE_TTL_MIN=30

# =========================================
# AI Categories — Claude model + image generator per tier
# =========================================
AI_CATEGORY_SIMPLES_CLAUDE_MODEL=claude-haiku-4-5
AI_CATEGORY_SIMPLES_IMAGE_GENERATOR=fal
AI_CATEGORY_MEDIO_CLAUDE_MODEL=claude-sonnet-4-6
AI_CATEGORY_MEDIO_IMAGE_GENERATOR=stability
AI_CATEGORY_AVANCADO_CLAUDE_MODEL=claude-opus-4-6
AI_CATEGORY_AVANCADO_IMAGE_GENERATOR=openai

# Credit costs per operation x category
CREDITS_COST_GENERATE_SIMPLES=4
CREDITS_COST_GENERATE_MEDIO=20
CREDITS_COST_GENERATE_AVANCADO=80
CREDITS_COST_REFINE_SIMPLES=2
CREDITS_COST_REFINE_MEDIO=10
CREDITS_COST_REFINE_AVANCADO=40
CREDITS_COST_CAPTION_SIMPLES=1
CREDITS_COST_CAPTION_MEDIO=3
CREDITS_COST_CAPTION_AVANCADO=10

# =========================================
# Plans
# =========================================
PLAN_FREE_MONTHLY_CREDITS=0

PLAN_BASIC_MONTHLY_CREDITS=100
PLAN_BASIC_PRICE_BRL_MONTHLY=29.90
PLAN_BASIC_PRICE_BRL_ANNUAL=299.00
PLAN_BASIC_STRIPE_PRICE_ID_MONTHLY=
PLAN_BASIC_PAGARME_PLAN_ID_ANNUAL=

PLAN_STANDARD_MONTHLY_CREDITS=500
PLAN_STANDARD_PRICE_BRL_MONTHLY=79.90
PLAN_STANDARD_PRICE_BRL_ANNUAL=799.00
PLAN_STANDARD_STRIPE_PRICE_ID_MONTHLY=
PLAN_STANDARD_PAGARME_PLAN_ID_ANNUAL=

PLAN_PREMIUM_MONTHLY_CREDITS=2000
PLAN_PREMIUM_PRICE_BRL_MONTHLY=199.90
PLAN_PREMIUM_PRICE_BRL_ANNUAL=1999.00
PLAN_PREMIUM_STRIPE_PRICE_ID_MONTHLY=
PLAN_PREMIUM_PAGARME_PLAN_ID_ANNUAL=

# =========================================
# One-off credit packages
# =========================================
CREDIT_PACKAGE_IDS=small,medium,large

CREDIT_PACKAGE_SMALL_LABEL=Pacote Starter
CREDIT_PACKAGE_SMALL_CREDITS=200
CREDIT_PACKAGE_SMALL_PRICE_BRL=19.90
CREDIT_PACKAGE_SMALL_STRIPE_PRICE_ID=

CREDIT_PACKAGE_MEDIUM_LABEL=Pacote Plus
CREDIT_PACKAGE_MEDIUM_CREDITS=750
CREDIT_PACKAGE_MEDIUM_PRICE_BRL=59.90
CREDIT_PACKAGE_MEDIUM_STRIPE_PRICE_ID=

CREDIT_PACKAGE_LARGE_LABEL=Pacote Pro
CREDIT_PACKAGE_LARGE_CREDITS=3000
CREDIT_PACKAGE_LARGE_PRICE_BRL=199.90
CREDIT_PACKAGE_LARGE_STRIPE_PRICE_ID=

# =========================================
# Stripe
# =========================================
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_SUCCESS_URL=http://localhost:3000/billing/success
STRIPE_CANCEL_URL=http://localhost:3000/billing/cancel

# =========================================
# Pagar.me
# =========================================
PAGARME_API_KEY=
PAGARME_WEBHOOK_SECRET=
PAGARME_SUCCESS_URL=http://localhost:3000/billing/success
PAGARME_CANCEL_URL=http://localhost:3000/billing/cancel
